terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "= 6.52.0"
    }
  }
}

provider "aws" {
  region      = "us-west-2"
  retry_mode  = "adaptive"
  max_retries = 25
  assume_role {
    role_arn    = "arn:aws:iam::123456789012:role/io-terraform"
    external_id = "external-123"
  }
}
